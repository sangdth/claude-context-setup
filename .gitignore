# =========================
# Docker & Docker Compose
# =========================
# Ignore local override files but keep the main docker-compose.yml
docker-compose.override.yml
docker-compose.override.yaml
docker-compose.local.yml

# Ignore Docker daemon configuration/state if mounted locally
.docker/

# =========================
# Milvus & Dependencies
# =========================
# Milvus relies on etcd, MinIO (or S3), and its own local volumes.
# Ignore these local data directories to prevent committing massive database files.
/volumes/
/data/
/milvus/
/milvus_data/
/minio_data/
/etcd_data/

# Ignore Milvus and container logs
/logs/
*.log
milvus*.log

# =========================
# Environment Variables & Secrets
# =========================
# DO NOT commit sensitive environment variables or keys!
.env
.env.local
.env.development
.env.test
.env.production

# (Optional) If you use a sample env file, force it to be tracked:
# !.env.example

# Security keys/certificates
*.pem
*.key
*.cert
*.crt

# =========================
# Application / SDK Specific
# =========================
# Assuming Python is used (e.g., PyMilvus)
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env/
pip-log.txt
.pytest_cache/

# Assuming Node.js is used (e.g., Milvus Node SDK)
node_modules/
npm-debug.log
yarn-error.log

# =========================
# IDEs & Editors
# =========================
.vscode/
.idea/
*.swp
*.swo
.settings/

# =========================
# OS Generated Files
# =========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
